# Server connection (use hostname if using Tailscale/VPN, or IP address)
SERVER_HOST=your-server-hostname
SERVER_USER=root

# Paths on server
SERVER_CREDS_PATH=/root/.claude/.credentials.json
SERVER_PUSH_TIMESTAMP=/root/.openclaw/last-laptop-push

# Paths on laptop (defaults should work for most setups)
LAPTOP_CREDS_PATH=~/.claude/.credentials.json

# SSH key (optional, uses default if not set)
SSH_KEY_PATH=

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.claude-token-push</string>
    <key>ProgramArguments</key>
    <array>
        <!-- UPDATE THIS PATH to where you cloned the repo -->
        <string>/Users/YOUR_USERNAME/openclaw-claude-oauth-hybrid-sync/laptop/push-claude-tokens.sh</string>
    </array>
    <key>StartInterval</key>
    <!-- Push every 4 hours (14400 seconds) -->
    <integer>14400</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/claude-token-push.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/claude-token-push.err</string>
</dict>
</plist>
